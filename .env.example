# 1:100万基础地理信息 PostGIS MCP 服务 - 环境变量示例
# 复制为 .env 后按需修改：cp .env.example .env

# 数据库
POSTGRES_DB=gis_data
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password

# 宿主机映射端口（默认 5433，避免与宿主机或其他 Docker 中的 Postgres 冲突；若需使用 5432 可改为 5432）
POSTGRES_PORT=5433

# Supergateway（启用 profile: gateway 时使用）
GATEWAY_SSE_PORT=8000
GATEWAY_WS_PORT=8001
GATEWAY_LOG_LEVEL=info
